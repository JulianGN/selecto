{
  "name": "selecto-onboarding-sdk",
  "version": "1.1.0",
  "description": "Client-side onboarding tour and guide runner leveraging Selecto SDK.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name SelectoOnboarding --dts",
    "dev": "tsup src/index.ts --format cjs,esm,iife --global-name SelectoOnboarding --dts --watch"
  },
  "dependencies": {
    "selecto-sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "user-onboarding",
    "onboarding",
    "product-tours",
    "walkthroughs"
  ],
  "author": "Selecto Authors",
